# =====================================================================
# DahmerIA - Configuração
# =====================================================================

# Porta do servidor backend
PORT=3001

# ---------------------------------------------------------------------
# PROVIDER DEFAULT
# ---------------------------------------------------------------------
# Qual provider usar quando o frontend não envia escolha:
#   "auto"   -> usa Gemini se chave configurada, senão Ollama
#   "gemini" -> sempre Gemini
#   "ollama" -> sempre Ollama local
DEFAULT_PROVIDER=auto


# =====================================================================
# PROVIDER 1: GEMINI (cloud, recomendado para LER IMAGENS)
# =====================================================================
# Lê fórmulas, gráficos, scatter plots, manuscritos com qualidade nível
# GPT-4. Tier gratuito tem cota diária por modelo (varia: 20 a 1000 req/dia).
#
# Como pegar uma chave gratuita:
#   1. Acesse https://aistudio.google.com/apikey
#   2. Clique "Create API key" (não precisa cartão)
#   3. Cole abaixo (sem aspas):
GEMINI_API_KEY=

# Modelo Gemini. Recomendado: gemini-2.5-flash (rápido + qualidade).
# Outras opções: gemini-2.5-flash-lite (cota maior), gemini-2.0-flash, gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash


# =====================================================================
# PROVIDER 2: OLLAMA (local, offline)
# =====================================================================
OLLAMA_URL=http://localhost:11434

# Modelo de TEXTO (usado quando o modo OCR está ativo)
# Exemplos: llama3, llama3.1, mistral, qwen2, phi3
OLLAMA_TEXT_MODEL=llama3

# Modelo MULTIMODAL (recebe imagem direto). Pra hardware modesto, modelos
# pequenos ALUCINAM em texto longo — em PT, prefira Gemini.
# Exemplos: llava, llava:13b, llama3.2-vision, moondream
OLLAMA_VISION_MODEL=llava

# Estratégia do Ollama:
#   "ocr"    -> SEMPRE OCR + modelo de texto (mais confiável em hardware modesto)
#   "vision" -> SEMPRE multimodal local (qualidade depende do modelo)
#   "auto"   -> tenta visão; se a resposta parecer ruim, cai pra OCR
PROCESSING_MODE=ocr

# Idiomas que o Tesseract OCR deve reconhecer
OCR_LANGS=por+eng

# Caminho do executável do Tesseract no Windows.
# Deixe em branco se você tem o tesseract no PATH; senão aponte para o .exe.
# Exemplo: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
